{
  "name": "@eliya-oss/agent-slack",
  "version": "0.1.11",
  "description": "Slack context CLI for AI agents.",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "bin": {
    "agent-slack": "dist/main.js",
    "aslk": "dist/main.js"
  },
  "files": [
    "dist",
    "assets",
    "skills",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    ".agents/cli-api.md"
  ],
  "scripts": {
    "build": "rolldown -c rolldown.config.mjs",
    "check": "pnpm typecheck && pnpm test:coverage && pnpm build",
    "changeset": "changeset",
    "clean": "rm -rf dist coverage",
    "dev": "rolldown -c rolldown.config.mjs && node dist/main.js",
    "docs:build": "pnpm --filter docs build",
    "docs:dev": "pnpm --filter docs dev",
    "docs:types": "pnpm --filter docs types:check",
    "prepack": "pnpm build",
    "release:check": "pnpm check && npm pack --dry-run",
    "release:publish": "pnpm build && changeset publish",
    "agent-slack": "rolldown -c rolldown.config.mjs && node dist/main.js",
    "aslk": "rolldown -c rolldown.config.mjs && node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:emulate": "vitest run tests/emulate",
    "version-packages": "changeset version"
  },
  "keywords": [
    "slack",
    "cli",
    "agents",
    "effect",
    "oauth"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.93",
    "@slack/web-api": "7.18.0",
    "effect": "4.0.0-beta.93"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@effect/vitest": "4.0.0-beta.93",
    "@types/node": "latest",
    "@vitest/coverage-v8": "^4.1.9",
    "emulate": "^0.8.0",
    "rolldown": "^1.1.4",
    "typescript": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=22"
  }
}
